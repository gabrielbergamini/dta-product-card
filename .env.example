# Store for `npm run dev` (tools/theme-dev.ts) and tools/seed.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Storefront password — only needed while the store is password-protected.
SHOPIFY_STORE_PASSWORD=xxxxxx
# Admin API custom app token for tools/seed only.
# Admin → Settings → Apps and sales channels → Develop apps → Create an app.
# Required Admin API scopes: write_products, read_products, write_files,
# read_files, write_publications, read_publications.
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
