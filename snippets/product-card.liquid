{%- comment -%}
  Product card.

  Accepts:
  - product: {Product} required
  - loading: {String} 'eager' | 'lazy' for the primary image (default 'lazy')

  Adapts to the product's data: sale badge + markdown pricing only when the
  selected variant is on sale; variant selectors only when the product has a
  real option (option values whose admin swatch defines a color — native
  color-pattern taxonomy metaobjects — render as circles, anything else
  renders as a labeled chip); hover image only when one exists.

  Hover (secondary) image resolution, per variant:
  1. `variant.metafields.custom.hover_image` (file_reference — merchant-editable)
  2. product media whose alt text is "<option value> secondary" (case-insensitive)
  3. for option-less products: the product's second media
{%- endcomment -%}

{%- liquid
  assign loading = loading | default: 'lazy'
  assign sizes = '(min-width: 1280px) 25vw, (min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw'
  assign srcset_widths = '360,540,720,900,1000' | split: ','
  assign selected_variant = product.selected_or_first_available_variant

  assign selector_option = blank
  for option in product.options_with_values
    assign option_name = option.name | downcase
    if option_name == 'color' or option_name == 'colour'
      assign selector_option = option
      break
    endif
  endfor
  if selector_option == blank and product.has_only_default_variant == false
    assign selector_option = product.options_with_values | first
  endif

  if selector_option != blank
    assign option_index = selector_option.position | minus: 1
    assign selected_value = selected_variant.options[option_index]
  endif

  assign card_url = selected_variant.url
  if product.has_only_default_variant
    assign card_url = product.url
  endif

  assign primary_media = selected_variant.featured_media | default: product.featured_media

  assign secondary_media = selected_variant.metafields.custom.hover_image.value
  if secondary_media == blank
    if selector_option != blank
      assign secondary_alt = selected_value | downcase | append: ' secondary'
      for media in product.media
        assign media_alt = media.alt | downcase
        if media_alt == secondary_alt
          assign secondary_media = media
          break
        endif
      endfor
    elsif product.media.size > 1
      assign secondary_media = product.media[1]
    endif
  endif

  assign on_sale = false
  if selected_variant.compare_at_price > selected_variant.price
    assign on_sale = true
  endif
-%}

{% # font-sans is set here (not inherited from body) because Skeleton's critical.css owns the body font %}
{% # Named group (group/card, never bare `group`): Skeleton's compiled_assets/styles.css ships a `.group` component class (overflow:hidden + flex/nowrap/w-full) that a bare Tailwind `group` marker collides with — the overflow:hidden clipped the leftmost swatch/chip selection ring. The /card suffix dodges that selector. %}
<product-card class='group/card flex w-full flex-col gap-[15px] font-sans'>
  {% # data-[swipe-enabled]:touch-pan-y reserves the horizontal axis for the JS swipe handler (product-card.ts preventDefaults pointermove) while keeping native vertical scroll. Without it the browser claims the horizontal drag for scrolling and the touch image-swap never fires. JS toggles data-swipe-enabled only when a secondary image exists. %}
  <div class='card-media group/media relative aspect-[315/340] w-full overflow-hidden rounded-[10px] border border-line bg-white data-[swipe-enabled]:touch-pan-y'>
    <a href='{{ card_url }}' data-card-link tabindex='-1' aria-hidden='true' class='absolute inset-0 block'>
      {%- if primary_media -%}
        {%- assign primary_img = primary_media.preview_image -%}
        {%- assign primary_alt = primary_media.alt | default: product.title -%}
        <img
          data-primary-image
          src='{{ primary_img | image_url: width: 630 }}'
          srcset='{% for width_string in srcset_widths %}{% assign width = width_string | plus: 0 %}{% if width <= primary_img.width %}{{ primary_img | image_url: width: width }} {{ width }}w{% unless forloop.last %}, {% endunless %}{% endif %}{% endfor %}'
          sizes='{{ sizes }}'
          width='{{ primary_img.width }}'
          height='{{ primary_img.height }}'
          alt='{{ primary_alt | escape }}'
          loading='{{ loading }}'
          {% if loading == 'eager' %}
            fetchpriority='high'
          {% endif %}
          {% # Photos fill the whole box with object-contain (never cropped): square images span the full width, tall ones the full height, all centered. The photos' own whitespace provides the breathing room; the 5px inline padding matches the Figma card's inset. %}
          {% # Resting opacity-100; fades to 0 on desktop hover (only when a visible secondary exists). On coarse pointers the swipe progress drives opacity instead. %}
          class='absolute inset-0 size-full object-contain px-[5px] opacity-100 transition-opacity duration-200 ease-[ease] motion-reduce:transition-none group-data-[swipe-dragging]/media:transition-none [@media(hover:none)]:group-data-[swipe-enabled]/media:opacity-[calc(1_-_var(--image-swipe-progress,0))] pointer-coarse:group-data-[swipe-enabled]/media:opacity-[calc(1_-_var(--image-swipe-progress,0))] any-pointer-coarse:group-data-[swipe-enabled]/media:opacity-[calc(1_-_var(--image-swipe-progress,0))] [@media(hover:none)]:group-data-[swipe-enabled]/media:select-none pointer-coarse:group-data-[swipe-enabled]/media:select-none any-pointer-coarse:group-data-[swipe-enabled]/media:select-none [@media(hover:none)]:group-data-[swipe-enabled]/media:[-webkit-user-drag:none] pointer-coarse:group-data-[swipe-enabled]/media:[-webkit-user-drag:none] any-pointer-coarse:group-data-[swipe-enabled]/media:[-webkit-user-drag:none] pointer-fine:group-has-[[data-secondary-image]:not([hidden])]/card:group-hover/card:opacity-0'
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'absolute inset-0 size-full text-line' }}
      {%- endif -%}
      {%- if secondary_media != blank or selector_option != blank -%}
        {%- liquid
          assign secondary_img = secondary_media.preview_image | default: secondary_media
          assign secondary_width = secondary_img.width | default: 800
          assign secondary_height = secondary_img.height | default: 1000
        -%}
        <img
          data-secondary-image
          {% if secondary_media != blank %}
            src='{{ secondary_img | image_url: width: 630 }}'
            srcset='{% for width_string in srcset_widths %}{% assign width = width_string | plus: 0 %}{% if width <= secondary_img.width %}{{ secondary_img | image_url: width: width }} {{ width }}w{% unless forloop.last %}, {% endunless %}{% endif %}{% endfor %}'
            sizes='{{ sizes }}'
          {% else %}
            hidden
          {% endif %}
          width='{{ secondary_width }}'
          height='{{ secondary_height }}'
          alt=''
          aria-hidden='true'
          loading='lazy'
          {% # Resting opacity-0; fades in on desktop hover. On coarse pointers the swipe progress drives opacity. %}
          class='absolute inset-0 size-full object-contain px-[5px] opacity-0 transition-opacity duration-200 ease-[ease] motion-reduce:transition-none group-data-[swipe-dragging]/media:transition-none [@media(hover:none)]:group-data-[swipe-enabled]/media:opacity-[var(--image-swipe-progress,0)] pointer-coarse:group-data-[swipe-enabled]/media:opacity-[var(--image-swipe-progress,0)] any-pointer-coarse:group-data-[swipe-enabled]/media:opacity-[var(--image-swipe-progress,0)] [@media(hover:none)]:group-data-[swipe-enabled]/media:select-none pointer-coarse:group-data-[swipe-enabled]/media:select-none any-pointer-coarse:group-data-[swipe-enabled]/media:select-none [@media(hover:none)]:group-data-[swipe-enabled]/media:[-webkit-user-drag:none] pointer-coarse:group-data-[swipe-enabled]/media:[-webkit-user-drag:none] any-pointer-coarse:group-data-[swipe-enabled]/media:[-webkit-user-drag:none] pointer-fine:group-hover/card:opacity-100'
        >
      {%- endif -%}
    </a>
    {%- liquid
      # Desktop badge calibrated against the Figma export pixel-by-pixel: Franklin Gothic ATF
      # (Adobe-licensed, not shipped) renders 54×11px of text ink in a 91×29 pill; Libre Franklin 400
      # at 15.3px + 15.1px x-padding reproduces those measurements. Tablet ≈ ×0.88, mobile ≈ ×0.78.
      # The frosted background (white/75 + blur) is invisible over the white card but keeps the red
      # legible if a photo ever extends under the badge.
      assign badge_classes = 'absolute items-center rounded-full border border-sale bg-white/75 font-badge leading-none font-normal text-sale backdrop-blur-[2px] top-[14px] left-[14px] h-[23px] px-[11.8px] text-[12px] min-[480px]:top-[16px] min-[480px]:left-[16px] min-[480px]:h-[26px] min-[480px]:px-[13.3px] min-[480px]:text-[13.5px] lg:top-[19px] lg:left-[19px] lg:h-[29.45px] lg:px-[15.1px] lg:text-[15.3px]'
      assign custom_badge = product.metafields.custom.badge.value
    -%}
    {%- if on_sale or selector_option != blank -%}
      <span
        data-badge
        {% unless on_sale %}
          hidden
        {% endunless %}
        {% # peer: when this sale badge is visible, a sibling rule on the custom badge hides it. %}
        class='peer inline-flex {{ badge_classes }}'
      >
        {{ 'products.card.on_sale' | t }}
      </span>
    {%- endif -%}
    {%- if custom_badge != blank -%}
      {% # Product-level label ("New", "Best Seller") from the custom.badge metafield. The sale badge wins while visible — peer-[:not([hidden])]:hidden hides this one when the sale peer is shown. %}
      <span data-badge-custom class='inline-flex peer-[:not([hidden])]:hidden {{ badge_classes }}'>
        {{- custom_badge -}}
      </span>
    {%- endif -%}
    {%- if secondary_media != blank or selector_option != blank -%}
      <span
        data-image-pagination
        aria-hidden='true'
        {% if secondary_media == blank %}
          hidden
        {% endif %}
        {% # Hidden by default; shown as a flex row only on coarse/touch pointers (and never when [hidden]). %}
        class='absolute bottom-[10px] left-1/2 z-[1] hidden items-center gap-1 rounded-full border border-line/80 bg-white/75 px-[7px] py-[5px] shadow-[0_1px_4px_rgb(17_17_17/0.08)] backdrop-blur-[3px] pointer-events-none -translate-x-1/2 [@media(hover:none)]:[&:not([hidden])]:flex pointer-coarse:[&:not([hidden])]:flex any-pointer-coarse:[&:not([hidden])]:flex'
      >
        <span
          data-image-dot='primary'
          class='size-[5px] rounded-full bg-ink/35 transition-[width,background-color] duration-[180ms] ease-[ease] motion-reduce:transition-none group-data-[image-view=primary]/media:w-[12px] group-data-[image-view=primary]/media:bg-accent'
        ></span>
        <span
          data-image-dot='secondary'
          class='size-[5px] rounded-full bg-ink/35 transition-[width,background-color] duration-[180ms] ease-[ease] motion-reduce:transition-none group-data-[image-view=secondary]/media:w-[12px] group-data-[image-view=secondary]/media:bg-accent'
        ></span>
      </span>
    {%- endif -%}
  </div>

  <div class='flex w-full flex-col gap-[15px]'>
    {%- if selector_option != blank -%}
      {% # Negative margins offset the labels' hit-area padding so the visual row matches the 20px design while keeping 28px touch targets %}
      <fieldset class='-mx-1 -my-1 flex flex-wrap items-center border-0 p-0'>
        <legend class='sr-only'>{{ selector_option.name }}</legend>
        {%- for value in selector_option.values -%}
          {%- liquid
            assign value_variant = blank
            for variant in product.variants
              if variant.options[option_index] == value
                assign value_variant = variant
                break
              endif
            endfor
            comment
              Native swatch: the option value's admin-managed color-pattern
              metaobject (set when the option is linked to shopify.color-pattern).
              No swatch (or an image-only one) falls back to the labeled chip.
            endcomment
            assign swatch_color = value.swatch.color
          -%}
          {%- if value_variant != blank -%}
            {%- if swatch_color -%}
              <label class='group/swatch relative grid size-7 cursor-pointer place-items-center'>
                <input
                  type='radio'
                  name='option-{{ section.id | default: 'grid' }}-{{ product.id }}'
                  value='{{ value | escape }}'
                  data-swatch
                  {% if value == selected_value %}
                    checked
                  {% endif %}
                  class='peer absolute inset-0 size-full cursor-pointer appearance-none rounded-full focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent'
                >
                {% # The hover sweep ring is the ::after pseudo-element (conic-gradient + radial mask), animated via the registered --sweep angle off the pointer-entry --enter angle (set on the label by product-card.ts). Double-quoted so after:content-[''] can use single quotes. Decorative — gated behind motion-safe. %}
                <span
                  aria-hidden='true'
                  class="swatch-dot relative size-5 rounded-full peer-checked:ring-1 peer-checked:ring-accent peer-checked:ring-offset-1 motion-safe:transition-[box-shadow] motion-safe:duration-[350ms] motion-safe:ease-[ease] motion-safe:after:content-[''] motion-safe:after:absolute motion-safe:after:inset-[-2px] motion-safe:after:rounded-full motion-safe:after:pointer-events-none motion-safe:after:[--sweep:0deg] motion-safe:after:[background:conic-gradient(from_var(--enter,0deg),rgb(138_146_158/0.95)_0deg,rgb(138_146_158/0.95)_calc(var(--sweep)_-_24deg),transparent_var(--sweep))] motion-safe:after:[mask:radial-gradient(farthest-side,transparent_calc(100%_-_1.4px),#000_calc(100%_-_1px))] motion-safe:after:transition-[--sweep] motion-safe:after:duration-500 motion-safe:after:ease-out motion-safe:group-hover/swatch:peer-[:not(:checked)]:after:[--sweep:384deg]"
                  style='background-color: {{ swatch_color }};'
                ></span>
                <span class='sr-only'>{{ value }}</span>
              </label>
            {%- else -%}
              <label class='relative m-1 flex cursor-pointer'>
                <input
                  type='radio'
                  name='option-{{ section.id | default: 'grid' }}-{{ product.id }}'
                  value='{{ value | escape }}'
                  data-swatch
                  {% if value == selected_value %}
                    checked
                  {% endif %}
                  class='peer absolute inset-0 size-full cursor-pointer appearance-none rounded-[6px] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent'
                >
                <span
                  class='flex h-7 items-center rounded-[6px] border border-line bg-white px-2.5 text-sm leading-4 text-ink peer-checked:border-accent peer-checked:text-accent peer-checked:ring-1 peer-checked:ring-accent'
                >
                  {{- value -}}
                </span>
              </label>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </fieldset>
    {%- endif -%}

    <div class='flex flex-col gap-1.5'>
      {%- if product.vendor != blank -%}
        <p class='text-sm leading-4 text-ink'>{{ product.vendor }}</p>
      {%- endif -%}
      <h3 class='line-clamp-2 text-base leading-[18px] font-medium text-accent'>
        <a
          href='{{ card_url }}'
          data-card-link
          {% # Underline grows from the left on hover, exits to the right on leave (background-position swaps while the line is at 0%/100% width so the jump is hidden); box-decoration-clone gives each wrapped line its own underline. %}
          class='card-title-link bg-[linear-gradient(currentColor,currentColor)] bg-no-repeat bg-[length:0%_1px] bg-[position:100%_100%] box-decoration-clone transition-[background-size] duration-300 ease-[ease] hover:bg-[length:100%_1px] hover:bg-[position:0%_100%] motion-reduce:transition-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent'
        >
          {{ product.title }}
        </a>
      </h3>
      <p class='flex gap-2 text-sm leading-4' aria-live='polite'>
        <span
          data-price-compare
          class='text-ink'
          {% unless on_sale %}
            hidden
          {% endunless %}
        >
          <span class='sr-only'>{{ 'products.card.regular_price' | t }}&nbsp;</span>
          <s data-price-compare-value>{{ selected_variant.compare_at_price | money }}</s>
        </span>
        <span data-price-current class='{% if on_sale %}text-sale{% else %}text-ink{% endif %}'>
          <span
            data-price-sale-label
            class='sr-only'
            {% unless on_sale %}
              hidden
            {% endunless %}
          >
            {{- 'products.card.sale_price' | t }}&nbsp;
          </span>
          <span data-price-current-value>{{ selected_variant.price | money }}</span>
        </span>
      </p>
    </div>
  </div>

  {%- if selector_option != blank -%}
    {%- assign payload_entries = '' -%}
    {%- for value in selector_option.values -%}
      {%- liquid
        assign payload_variant = blank
        for variant in product.variants
          if variant.options[option_index] == value
            assign payload_variant = variant
            break
          endif
        endfor
      -%}
      {%- if payload_variant != blank -%}
        {%- liquid
          assign pv_primary = payload_variant.featured_media | default: product.featured_media
          assign pv_secondary = payload_variant.metafields.custom.hover_image.value
          if pv_secondary == blank
            assign pv_secondary_alt = value | downcase | append: ' secondary'
            for media in product.media
              assign media_alt = media.alt | downcase
              if media_alt == pv_secondary_alt
                assign pv_secondary = media
                break
              endif
            endfor
          endif
          assign pv_on_sale = false
          if payload_variant.compare_at_price > payload_variant.price
            assign pv_on_sale = true
          endif
        -%}
        {%- capture entry -%}
          {"id": {{ payload_variant.id }}, "value": {{ value | json }}, "available": {{ payload_variant.available }}, "onSale": {{ pv_on_sale }}, "price": {{ payload_variant.price | money | json }}, "compareAtPrice": {% if payload_variant.compare_at_price %}{{ payload_variant.compare_at_price | money | json }}{% else %}null{% endif %}, "url": {{ payload_variant.url | json }}, "primaryImage": {% render 'product-card-image-json', media: pv_primary, product: product %}, "secondaryImage": {% render 'product-card-image-json', media: pv_secondary, product: product %}}
        {%- endcapture -%}
        {%- assign payload_entries = payload_entries | append: entry | append: '@@SEP@@' -%}
      {%- endif -%}
    {%- endfor -%}
    <script type='application/json' data-card-payload>
      {"variants":[{{ payload_entries | split: '@@SEP@@' | join: ',' }}]}
    </script>
  {%- endif -%}
</product-card>
